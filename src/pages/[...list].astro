---
import { getCollection } from 'astro:content';
import Footer from '../components/Footer.astro';
import Head from '../components/Head.astro';
import '../styles/global.css';

type ListType = 'post' | 'star';

type Props = {
	type: ListType;
	tag?: string;
};

export const getStaticPaths = async () => {
	const posts = await getCollection('posts');
	const tags = new Set(posts.flatMap(post => post.data.tags));
	return [
		/* post list */ { params: { list: undefined }, props: { type: 'post' } },
		/* tagged post list */ ...Array.from(tags).map(tag => ({ params: { list: `/tagged/${tag}` }, props: { type: 'post', tag } })),
		/* stars list */ { params: { list: '/star' }, props: { type: 'star' } },
	];
};

const { type, tag } = Astro.props;

const titleMap: Record<ListType, string> = {
	post: tag ? '#' + tag + " at qsliu's blog" : "qsliu's blog",
	star: "qsliu's stars",
};

const navItems = [
	{ href: '/', text: 'Posts', active: type === 'post' && !tag },
	{ href: '/star', text: 'Stars', active: type === 'star' },
	...(tag ? [{ href: `/tagged/${tag}`, text: `Posts#${tag}`, active: true }] : []),
];

type Section = { section: string };

type Link = {
	title: string;
	url: string;
	isExternal?: boolean;
	date?: Date;
	draft?: boolean;
};

type Item = Section | Link;

const getPostItems = async () => {
	const posts = await getCollection('posts');
	const postItems = posts
		.filter(post => !tag || post.data.tags.includes(tag))
		.map(({ id, data: { title, date, draft, externalUrl } }) => ({
			url: externalUrl || `/post/${id}/`,
			title,
			date,
			draft,
			isExternal: !!externalUrl,
		}));
	const itemsOfYear = Object.groupBy(postItems, item => item.date.getFullYear());
	return Object.entries(itemsOfYear)
		.sort(([a], [b]) => Number(b) - Number(a))
		.flatMap(([year, items]) => [{ section: year }, ...items!.sort((a, b) => b.date.valueOf() - a.date.valueOf())]);
};

const getStarItems = async () => {
	const starItems = (await getCollection('stars')).flatMap(list => {
		const items = list.data.entry
			.sort((a, b) => a.title.localeCompare(b.title))
			.flatMap(({ title, url, posts }) => [
				{ title, url, isExternal: true },
				...(posts?.map(({ title, url }, idx) => ({
					title: (idx < posts.length - 1 ? '├─ ' : '└─ ') + title,
					url,
					isExternal: true,
				})) ?? []),
			]);
		return [{ section: list.id }, ...items];
	});
	return starItems;
};

const itemsFnMap: Record<ListType, () => Promise<Item[]>> = {
	post: getPostItems,
	star: getStarItems,
};

const list = await itemsFnMap[type]();

const zeroPadding = (n: number) => (n < 10 ? '0' : '') + n;
const dateString = (date: Date) => zeroPadding(date.getMonth() + 1) + '/' + zeroPadding(date.getDate());
---

<!doctype html>
<html lang='en' class='theme-ayu text-pretty'>
	<Head title={titleMap[type]} />
	<body class='mx-auto w-main max-w-full px-6'>
		<main>
			<header class='pb-6 pt-10'>
				<a href='/' class='text-2xl font-bold tracking-tight hover:text-active'>qsliu's blog</a>
				<p class='mt-1 text-sm text-muted'>Notes on databases, systems, and software engineering.</p>
			</header>
			<nav class='mb-8 flex gap-5 border-b pb-3 text-sm'>
				{
					navItems.map(({ href, text, active }) => (
						<a {href} class={active ? 'font-semibold text-active' : 'text-muted hover:text-active'}>
							{text}
						</a>
					))
				}
			</nav>
			{
				list.map(item =>
					'section' in item ? (
						<h2 class='mb-1 mt-8 text-xs uppercase tracking-widest text-muted first:mt-0'>{item.section}</h2>
					) : (
						<a
							class='flex items-baseline justify-between gap-4 border-b py-2 last:border-b-0 hover:text-active'
							href={item.url}
							target={item.isExternal ? '_blank' : '_self'}
						>
							<span>
								{item.draft && (
									<>
										[<span class='underline'>draft</span>]
									</>
								)}
								{item.title}
								{item.isExternal && (
									<svg class='ml-0.5 inline-block text-muted' width='13' height='13' viewBox='0 0 15 15' fill='none' xmlns='http://www.w3.org/2000/svg'>
										<path
											d='M3 2C2.44772 2 2 2.44772 2 3V12C2 12.5523 2.44772 13 3 13H12C12.5523 13 13 12.5523 13 12V8.5C13 8.22386 12.7761 8 12.5 8C12.2239 8 12 8.22386 12 8.5V12H3V3L6.5 3C6.77614 3 7 2.77614 7 2.5C7 2.22386 6.77614 2 6.5 2H3ZM12.8536 2.14645C12.9015 2.19439 12.9377 2.24964 12.9621 2.30861C12.9861 2.36669 12.9996 2.4303 13 2.497L13 2.5V2.50049V5.5C13 5.77614 12.7761 6 12.5 6C12.2239 6 12 5.77614 12 5.5V3.70711L6.85355 8.85355C6.65829 9.04882 6.34171 9.04882 6.14645 8.85355C5.95118 8.65829 5.95118 8.34171 6.14645 8.14645L11.2929 3H9.5C9.22386 3 9 2.77614 9 2.5C9 2.22386 9.22386 2 9.5 2H12.4999H12.5C12.5678 2 12.6324 2.01349 12.6914 2.03794C12.7504 2.06234 12.8056 2.09851 12.8536 2.14645Z'
											fill='currentColor'
											fill-rule='evenodd'
											clip-rule='evenodd'
										/>
									</svg>
								)}
							</span>
							{item.date && (
								<time class='text-nowrap text-sm text-muted' datetime={item.date.toISOString()}>
									{dateString(item.date)}
								</time>
							)}
						</a>
					),
				)
			}
		</main>
		<Footer />
	</body>
</html>
