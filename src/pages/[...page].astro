---
import { getCollection, render } from 'astro:content';
import Footer from '../components/Footer.astro';
import Head from '../components/Head.astro';
import '../styles/global.css';

export async function getStaticPaths() {
	const posts = (await getCollection('posts'))
		.filter(post => post.data.theme !== 'tufte')
		.map(async (post) => ({
			props: { post: { ...post, rendered: await render(post) } },
			params: { page: `/post/${post.id}` },
		}));
	return await Promise.all(posts);
}

const { post } = Astro.props;
const { headings } = post.rendered;
---

<html lang='en' class='theme-ayu text-pretty'>
	<Head title={post.data.title} description={post?.data.description} ogType="article" publishDate={post.data.date} tags={post.data.tags} />
	<body class='grid md:grid-cols-[1fr_auto_1fr]'>
		<main class='w-full max-w-main px-4 md:col-start-2 md:px-0'>
			<nav class='pt-8 text-sm text-muted'>
				<a href='/' class='hover:text-active'>&larr; qsliu's blog</a>
			</nav>
			<header class='mb-8 mt-6'>
				<time class='text-sm text-muted' datetime={post.data.date.toISOString()}>
					{post.data.date.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
				</time>
				<h1 class='mt-2 break-words text-4xl font-bold leading-tight tracking-tight'>{post.data.title}</h1>
				{post.data.tags.length > 0 && (
					<div class='mt-3 flex flex-wrap gap-2 text-sm text-muted'>
						{post.data.tags.map(tag => (
							<a href={`/tagged/${tag}/`} class='hover:text-active'>#{tag}</a>
						))}
					</div>
				)}
			</header>
			<article class='rendered-content prose max-w-none'>
				<post.rendered.Content />
			</article>
			<Footer />
		</main>
		{headings.length > 1 && (
			<nav class='sticky top-8 col-start-3 mx-2 hidden space-y-1 self-start text-sm md:block'>
				{headings.map(({ text, depth, slug }) => (
					<a href={`#${slug}`} data-heading={slug} class:list={['block hover:text-blue-600', depth > 2 && 'ml-4']}>
						{text}
					</a>
				))}
			</nav>
		)}
		<script>
			(() => {
				const headingLinks = document.querySelectorAll('a[data-heading]');
				if (!headingLinks.length) return;

				const headingIdToLink = new Map(Array.from(headingLinks).map(link => [link.getAttribute('data-heading')!, link]));

				const highlightStyle = 'text-blue-600';
				const highlight = (link: Element) => {
					headingLinks.forEach(l => l.classList.remove(highlightStyle));
					link.classList.add(highlightStyle);
				};

				headingLinks.forEach(link => link.addEventListener('click', () => highlight(link)));

				const observer = new IntersectionObserver(
					entries => {
						const entry = entries.find(e => e.isIntersecting);
						if (entry) highlight(headingIdToLink.get(entry.target.id)!);
					},
					{ rootMargin: '-80px 0px -80% 0px' },
				);
				document.querySelectorAll('article :is(h1, h2, h3, h4, h5, h6)').forEach(heading => observer.observe(heading));

				const hash = window.location.hash.slice(1);
				highlight(headingIdToLink.get(hash) || headingLinks.item(0));
			})();
		</script>
	</body>
</html>
